
# Passage runtime must be explicit. Use demo or preview for non-production
# environments and production only for the customer production data plane.
PASSAGE_RUNTIME=demo

# Use the Supabase project URL and a publishable key only. Never place a
# service-role or secret key in a NEXT_PUBLIC variable.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# The URL-derived ref must match this binding and the runtime-specific binding.
PASSAGE_SUPABASE_PROJECT_REF=your-project-ref
PASSAGE_DEMO_SUPABASE_PROJECT_REF=your-project-ref
PASSAGE_PRODUCTION_SUPABASE_PROJECT_REF=your-production-project-ref

# Provider actions are fail-closed by default. Enabling email can send an
# authentication email; use only with an approved delivery or local capture.
PASSAGE_GOOGLE_AUTH_ENABLED=false
PASSAGE_EMAIL_AUTH_ENABLED=false

# Local Supabase is accepted only outside production, only with this explicit
# opt-in, and only at http://127.0.0.1:<port>. For local runs set both the
# general and demo project refs above to "local".
PASSAGE_ALLOW_LOCAL_SUPABASE=false

